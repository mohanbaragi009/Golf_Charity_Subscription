
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Extended user information stored in Firestore.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "handicap": { "type": "number" },
        "membershipLevel": { "type": "string", "enum": ["Basic Birdie", "Pro Eagle", "Elite Albatross"] },
        "totalDonated": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles identified by their Firebase Auth UID."
    }
  }
}
